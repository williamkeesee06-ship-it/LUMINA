# --- BROWSER (safe to expose, fronted by referrer restriction) ---
# Maps key — restrict by HTTP referrer in Google Cloud Console to your Vercel domain.
VITE_GOOGLE_MAPS_API_KEY=
# Google OAuth client ID — public by design.
VITE_GOOGLE_CLIENT_ID=

# --- SERVER ONLY (set in Vercel Project > Settings > Environment Variables) ---
# Smartsheet personal access token. Server-side only.
SMARTSHEET_TOKEN=
# Gemini API key. Server-side only.
GEMINI_API_KEY=
# Google Maps key for server-side geocoding (can reuse browser key but recommended to make a separate unrestricted server key).
GOOGLE_MAPS_API_KEY=
